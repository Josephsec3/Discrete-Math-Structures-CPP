#include <bits/stdc++.h>
using namespace std;

int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    long long n; cin >> n;
    long long sum=0, curr;
    for (int i = 0; i<n-1; i++){
      cin >> curr;
      sum+=curr;
    }
    cout << (n*(n+1)/2)-sum; //Triangular number equation
    return 0;
}
